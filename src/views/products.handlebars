<div class="page-header">
  <h1>Catálogo de Productos</h1>
  <form class="filters" method="GET" action="/products">
    <input type="text" name="query" placeholder="Buscar por categoría..." value="{{query}}" />
    <select name="sort">
      <option value="">Sin orden</option>
      <option value="asc" {{#if (eq sort "asc")}}selected{{/if}}>Precio: Menor a Mayor</option>
      <option value="desc" {{#if (eq sort "desc")}}selected{{/if}}>Precio: Mayor a Menor</option>
    </select>
    <button type="submit">Filtrar</button>
  </form>
</div>

<div class="products-grid">
  {{#each products}}
  <div class="product-card">
    {{#if thumbnails.[0]}}
    <img src="{{thumbnails.[0]}}" alt="{{title}}" class="product-img" />
    {{else}}
    <div class="product-img-placeholder">Sin imagen</div>
    {{/if}}
    <div class="product-info">
      <span class="category-badge">{{category}}</span>
      <h3>{{title}}</h3>
      <p class="description">{{description}}</p>
      <div class="product-footer">
        <span class="price">${{price}}</span>
        <span class="stock {{#if stock}}in-stock{{else}}out-stock{{/if}}">
          {{#if stock}}Stock: {{stock}}{{else}}Sin stock{{/if}}
        </span>
      </div>
      <a href="/products/{{_id}}" class="btn btn-detail">Ver detalle</a>
    </div>
  </div>
  {{else}}
  <p class="no-products">No se encontraron productos.</p>
  {{/each}}
</div>

<div class="pagination">
  <span>Página {{page}} de {{totalPages}}</span>
  <div class="pagination-links">
    {{#if hasPrevPage}}
    <a href="{{prevLink}}" class="btn">← Anterior</a>
    {{/if}}
    {{#if hasNextPage}}
    <a href="{{nextLink}}" class="btn">Siguiente →</a>
    {{/if}}
  </div>
</div>
